{
    "name": "indiveo/indiveo_oembed_drupal",
    "version": "1.0.0",
    "type": "drupal-module",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require-dev": {
        "drupal/oembed_providers": "^2.2.3"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "test": [
            "export SIMPLETEST_DB='sqlite://localhost/:memory:' && /opt/drupal/vendor/bin/phpunit --bootstrap /opt/drupal/web/core/tests/bootstrap.php /opt/drupal/web/modules/custom/indiveo_oembed_drupal"
        ]
    }
}